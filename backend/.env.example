# =================================
# DS Properties — Environment Variables
# =================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ---------- Server ----------
NODE_ENV=development
PORT=3000

# ---------- Database ----------
DATABASE_URL=postgresql://dsp_dev:dsp_dev_password@localhost:5432/dsp_development

# ---------- Authentication ----------
JWT_SECRET=CHANGE_ME_to_a_random_64_char_string
JWT_REFRESH_SECRET=CHANGE_ME_to_a_different_random_64_char_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Security ----------
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500

# ---------- Logging ----------
LOG_LEVEL=debug
